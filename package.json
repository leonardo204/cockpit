{
  "name": "@surething/cockpit",
  "version": "1.0.209",
  "description": "Claude Code GUI for parallel AI coding — drive Claude (default), OpenAI Codex, DeepSeek, Kimi, or local Ollama in tabs. Multi-project sessions, terminal, browser & DB bubbles, code review, slash modes. Local-first, MIT.",
  "author": "Robert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Surething-io/cockpit.git"
  },
  "homepage": "https://cocking.cc",
  "bugs": {
    "url": "https://github.com/Surething-io/cockpit/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-gui",
    "claude-code-desktop",
    "claude-code-client",
    "claude-agent-sdk",
    "anthropic",
    "openai-codex",
    "codex",
    "deepseek",
    "deepseek-gui",
    "kimi",
    "moonshot",
    "ollama",
    "ollama-gui",
    "multi-engine",
    "multi-model",
    "byok",
    "local-ai",
    "local-first",
    "ai-coding",
    "ai-coding-agent",
    "ai-ide",
    "ai-pair-programming",
    "ai-code-review",
    "agent-sdk",
    "coding-agent",
    "parallel-ai",
    "multi-project-ai",
    "cockpit",
    "cocking",
    "cursor-alternative",
    "aider-alternative",
    "continue-alternative",
    "ai",
    "cli",
    "agent",
    "developer-tools",
    "productivity"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared/*",
    "packages/feature/*"
  ],
  "bin": {
    "cockpit": "./bin/cockpit.mjs",
    "cock": "./bin/cock.mjs",
    "cock-dev": "./bin/cock-dev.mjs"
  },
  "files": [
    "bin",
    "chrome-extension",
    "public",
    "server.mjs",
    "dist",
    ".next-prod",
    "kernels",
    "next.config.mjs",
    "scripts/copy-tree-sitter-wasms.mjs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "predev": "node scripts/copy-tree-sitter-wasms.mjs",
    "dev": "COCKPIT_ENV=dev node --import tsx server.mjs",
    "prepublishOnly": "npm run build && npm run build:server && rm -rf .next-prod/cache",
    "prebuild": "node scripts/copy-tree-sitter-wasms.mjs",
    "build": "next build --webpack",
    "build:server": "tsup --config tsup.server.ts",
    "setup": "npm run build && npm run build:server && npm link",
    "lint": "eslint",
    "generate-icons": "node scripts/generate-icons.js",
    "copy-wasms": "node scripts/copy-tree-sitter-wasms.mjs",
    "postinstall": "node bin/postinstall.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@anthropic-ai/claude-agent-sdk": "^0.2.112",
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-table-cell": "^3.19.0",
    "@tiptap/extension-table-header": "^3.19.0",
    "@tiptap/extension-table-row": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@types/hast": "^3.0.4",
    "@types/pg": "^8.18.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vscode/ripgrep": "^1.17.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.154",
    "ansi_up": "^6.0.6",
    "fast-glob": "^3.3.3",
    "i18next": "^25.10.9",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.564.0",
    "mysql2": "^3.20.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.2.4",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "shiki": "^3.21.0",
    "tiptap-markdown": "^0.9.0",
    "unist-util-visit": "^5.1.0",
    "web-tree-sitter": "^0.26.8",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@cockpit/feature-agent": "*",
    "@cockpit/feature-comments": "*",
    "@cockpit/feature-console": "*",
    "@cockpit/feature-explorer": "*",
    "@cockpit/feature-review": "*",
    "@cockpit/feature-skills": "*",
    "@cockpit/feature-workspace": "*",
    "@cockpit/shared-i18n": "*",
    "@cockpit/shared-ui": "*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.91.1",
    "postcss": "^8.5.10"
  }
}
