{
  "name": "@surething/cockpit",
  "version": "1.0.245",
  "description": "The open-source Claude Code GUI \u2014 an IDE-like workbench for parallel AI coding. Drive Claude (default), Codex, DeepSeek, Kimi, or local Ollama in tabs. Terminal, browser & DB bubbles, code review. Self-host on a shared dev box \u2014 a seat for every teammate. Local-first, MIT.",
  "author": "Robert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Surething-io/cockpit.git"
  },
  "homepage": "https://opencockpit.dev",
  "bugs": {
    "url": "https://github.com/Surething-io/cockpit/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-gui",
    "claude-code-desktop",
    "claude-code-client",
    "claude-agent-sdk",
    "anthropic",
    "codex",
    "deepseek",
    "deepseek-gui",
    "kimi",
    "moonshot",
    "ollama",
    "ollama-gui",
    "multi-engine",
    "multi-model",
    "byok",
    "local-ai",
    "local-first",
    "ai-coding",
    "ai-coding-agent",
    "ai-ide",
    "ai-pair-programming",
    "ai-code-review",
    "agent-sdk",
    "coding-agent",
    "self-hosted",
    "web-ide",
    "remote-development",
    "multi-project-ai",
    "opencockpit",
    "cursor-alternative",
    "aider-alternative",
    "continue-alternative",
    "ai",
    "cli",
    "agent",
    "developer-tools",
    "productivity"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared/*",
    "packages/feature/*"
  ],
  "bin": {
    "cockpit": "./bin/cockpit.mjs",
    "cock": "./bin/cock.mjs",
    "cockpit-dev": "./bin/cockpit-dev.mjs"
  },
  "files": [
    "bin",
    "public",
    "server.mjs",
    "dist",
    ".next-prod",
    "next.config.mjs",
    "scripts/claudeBinary.mjs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "COCKPIT_ENV=dev node --import tsx server.mjs",
    "prepublishOnly": "npm run build && npm run build:server && rm -rf .next-prod/cache",
    "build": "next build --webpack",
    "build:server": "tsup --config tsup.server.ts",
    "setup": "npm run build && npm run build:server && npm link",
    "setup-dev": "node bin/setup-dev.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-icons": "node scripts/generate-icons.js",
    "postinstall": "node bin/postinstall.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-table-cell": "^3.19.0",
    "@tiptap/extension-table-header": "^3.19.0",
    "@tiptap/extension-table-row": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@types/hast": "^3.0.4",
    "@vscode/ripgrep": "^1.17.0",
    "ai": "^6.0.154",
    "fast-glob": "^3.3.3",
    "i18next": "^25.10.9",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.564.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "shiki": "^3.21.0",
    "tiptap-markdown": "^0.9.0",
    "unist-util-visit": "^5.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@cockpit/feature-agent": "*",
    "@cockpit/feature-workspace": "*",
    "@cockpit/shared-i18n": "*",
    "@cockpit/shared-ui": "*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
