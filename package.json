    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-storybook": "^10.3.6",
    "playwright": "^1.58.0",
    "sharp": "^0.34.5",
    "storybook": "^10.2.1",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
