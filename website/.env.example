# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit it.
#
# Used by:
#   - scripts/setup-cloudflare.sh  (one-shot Cloudflare + GitHub Secrets bootstrap)
#
# Not used by:
#   - Next.js dev/build (the website itself has no client-side secrets)
#   - Cloudflare Pages runtime (E2B_API_KEY there is set via Pages dashboard
#     or by the setup script via `wrangler pages secret put`)

# Cloudflare API token with scope: Account → Cloudflare Pages → Edit
# (Optionally add: Zone → DNS → Edit, scoped to opencockpit.dev, for auto domain bind)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# E2B sandbox API key — copy from your existing e2b/ Vercel project's env vars
# Used at runtime by functions/try.ts to create demo sandboxes
E2B_API_KEY=

# (Optional) Cloudflare account ID — only set this if:
#   a) the script can't auto-detect it (token lacks "list accounts" capability), or
#   b) your token has access to multiple accounts and you want a specific one.
# Find it at: dash.cloudflare.com → any page → right sidebar
# CLOUDFLARE_ACCOUNT_ID=
