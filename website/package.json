{
  "name": "cockpit-website",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing site for OpenCockpit (opencockpit.dev)",
  "scripts": {
    "dev": "env -u TURBOPACK next dev --webpack -p 3458",
    "build": "node scripts/fetch-changelog.mjs && node scripts/generate-og.mjs && NODE_ENV=production COCKPIT_VERSION=$(node -p \"require('../package.json').version\") env -u TURBOPACK next build --webpack",
    "start": "next start -p 3458",
    "lint": "next lint",
    "og": "node scripts/generate-og.mjs",
    "preview": "npx wrangler pages dev out --compatibility-date=2024-09-23"
  },
  "dependencies": {
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
